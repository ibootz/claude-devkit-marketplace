{
  "name": "working-discipline",
  "version": "1.1.0",
  "description": "AI 工作纪律每轮注入 - 上下文管理 / 子代理协作 / 表达约束（含求真·简体中文·列表编号） / 思维模式 / Agent 工具派发，一个 UserPromptSubmit hook",
  "author": {
    "name": "zhangq"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/working-discipline.js"
          }
        ]
      }
    ]
  }
}
