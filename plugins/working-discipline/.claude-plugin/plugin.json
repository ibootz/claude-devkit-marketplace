{
  "name": "working-discipline",
  "version": "1.3.1",
  "description": "AI 工作纪律注入 + 拦截 - 上下文管理 / 子代理协作（在飞≤16 动态上限·嵌套≤2 软约束）/ 表达约束（含求真·简体中文·列表编号）/ 思维模式 / Agent 工具派发。UserPromptSubmit 覆盖主会话每轮，SubagentStart 覆盖子代理；PreToolUse 硬拦截污染 cwd 的独立 cd 命令（block-cd）",
  "author": {
    "name": "zhangq"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/guards/block-cd.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/working-discipline.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/working-discipline.js"
          }
        ]
      }
    ]
  }
}
